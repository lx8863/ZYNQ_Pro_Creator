    // for the documentation about the tasks.json format

{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run ModelSim Simulation",
            "type": "shell",
            "command": "vsim",
            "args": [
                "-do", "vlog rtl/{{PROJECT_NAME}}.v sim/{{TB_NAME}}.v",
                "-do", "vsim -voptargs=+acc work.{{TB_NAME}}",
                "-do", "add wave -position insertpoint sim:/{{TB_NAME}}/uut/*",
                "-do", "run -all"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        }
    ]
}
